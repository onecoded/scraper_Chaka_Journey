# ============================================================
# LEAD GEN SYSTEM — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — only commit this .env.example file.
# ============================================================

# Claude / Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Apollo.io API (https://app.apollo.io/settings/integrations/api)
APOLLO_API_KEY=your-apollo-api-key

# SerpAPI for Google Search scraping (https://serpapi.com)
SERPAPI_KEY=your-serpapi-key

# Yelp Fusion API (https://www.yelp.com/developers) - free tier
YELP_API_KEY=your-yelp-api-key

# Hunter.io lead enrichment (https://hunter.io)
HUNTER_API_KEY=your-hunter-api-key

# Google Sheets export
GOOGLE_SHEET_ID=your-google-sheet-id-from-url
GOOGLE_CREDENTIALS_PATH=credentials.json

# Gmail API label (Phase 2 - email outreach)
GMAIL_AXIAL_LABEL=axial-deals

# Scraper settings
SCRAPER_DELAY_DEFAULT=2
SCRAPER_MAX_PAGES_DEFAULT=10

# Pipeline settings
MIN_MATCH_SCORE=40
EMAIL_MODEL=claude-haiku-4-5-20251001

# Broker info (appears in all outreach messages)
BROKER_NAME=Your Name
BROKER_COMPANY=Your Company
BROKER_LINKEDIN=https://www.linkedin.com/in/your-profile/

# File paths
PDF_PATH=BIZ BROKER MATCHES - buyers w agreements.pdf
BUYERS_JSON_PATH=.tmp/buyers.json

# ============================================================
# SOCIAL MEDIA CROSS-POSTER — Additional Keys
# ============================================================

# Meta (Facebook + Instagram) — from developers.facebook.com
# Create a Business App → get Page Access Token via Graph API Explorer
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_PAGE_ID=your-facebook-page-id
META_IG_USER_ID=your-instagram-user-id
META_PAGE_ACCESS_TOKEN=your-long-lived-page-token
# Run:  python tools/run_social.py --refresh-token   to get/renew tokens

# HuggingFace (free AI image/audio generation)
# Get token at huggingface.co → Settings → Access Tokens
HF_TOKEN=hf_...

# KIE.AI — Nano Banana (Google Gemini images) + Veo3 (video generation)
# Get API key at: https://kie.ai/api-key
# Buttons appear in the Streams tab: "KIE Image" and "KIE Video"
KIE_AI_API_KEY=your-kie-ai-api-key

# Email newsletter (Gmail SMTP)
# Use Gmail + App Password: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# YOUTUBE UPLOAD — Google Cloud Console
# console.cloud.google.com → Enable "YouTube Data API v3"
# Create OAuth2 Credentials (Desktop App type) → Download JSON
# Set this to the path of the downloaded credentials file
YOUTUBE_CREDENTIALS_FILE=C:/path/to/client_secret.json
# Token is auto-saved to .tmp/yt_token.json after first browser consent

# TIKTOK POSTING — developers.tiktok.com
# Create App → Enable video.publish + video.upload scopes
# Then run:  python tools/run_social.py --tiktok-auth
TK_CLIENT_KEY=your-tiktok-client-key
TK_CLIENT_SECRET=your-tiktok-client-secret
# Token is auto-saved to .tmp/tiktok_token.json after auth flow

# BUFFER SCHEDULING — buffer.com/developers
# Get personal access token from buffer.com/developers
# Run:  python tools/run_social.py --list-buffer-profiles
# to see your profile IDs, then fill in below
BUFFER_ACCESS_TOKEN=your-buffer-token
BUFFER_PROFILE_INSTAGRAM=your-ig-profile-id
BUFFER_PROFILE_FACEBOOK=your-fb-profile-id
BUFFER_PROFILE_TIKTOK=your-tt-profile-id
BUFFER_PROFILE_LINKEDIN=your-li-profile-id

# EXTRA FACEBOOK PAGES — add as many as needed
# Each page needs its own Page ID and Page Access Token
# Format:  EXTRA_FB_PAGE_{LABEL}_ID and EXTRA_FB_PAGE_{LABEL}_TOKEN
# Then add them in the Accounts tab of the dashboard
# Example:
# EXTRA_FB_PAGE_CLAIMS_ID=your-claims-page-id
# EXTRA_FB_PAGE_CLAIMS_TOKEN=EAA...

# Active brand name (overrides default in app — set per-session in UI instead)
# SOCIAL_BRAND_NAME=Evolve Earth Retreat Center
